# Application Settings
APP_NAME=project-template
VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=sqlite:///./app.db
# For PostgreSQL: postgresql://user:password@localhost/project-template

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# AWS Configuration
AWS_BUCKET_MODEL_INPUT=
AWS_REGION=

# GitLab Configuration
GITLAB_API_URL=
GITLAB_INSTANCE_ID=
GITLAB_INSTANCE_NAME=

# MongoDB Configuration
MONGODB_MAIN_SCHEMA=
SPRING_DATA_MONGODB_URI=

# S3 Configuration
S3_AWS_ACCESS_KEY_ID=
S3_AWS_SECRET_ACCESS_KEY=

# SQS Configuration
SQS_AWS_ACCESS_KEY_ID=
SQS_AWS_SECRET_ACCESS_KEY=
SQS_QUEUE_NAME=

# SSO Configuration
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_TENANT_ID=

# Sentry Configuration
SENTRY_ENVIRONMENT=
SENTRY_DSN=
